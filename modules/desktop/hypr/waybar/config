{
  "layer": "top",
  "position": "top",
  "height": 34,
  "font": "Inter Nerd Font:size=10",
  "background": "#111111",
  "border": "0px",
  "separator": false,
  "tray-position": "right",
  "tray-padding": 0,
  "modules-left": [],
  "modules-center": ["clock"],
  "modules-right": ["pulseaudio", "network", "cpu", "memory", "battery", "tray", "custom/logout"],

  "clock": {
    "format": "{:%H:%M}",
    "tooltip": true,
    "tooltip-format": "{:%A, %Y-%m-%d}",
    "on-doubleclick": "gsimplecal",
    "format-alt": "{:%Y-%m-%d %H:%M}"
  },

  "pulseaudio": {
    "format": " {volume}%",
    "format-muted": " muted",
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "tooltip": false
  },

  "network": {
    "format-connected": " {essid} {ipaddr}",
    "format-disconnected": "睊 无网络",
    "tooltip": false
  },

  "cpu": {
    "format": " {usage}%",
    "tooltip": false
  },

  "memory": {
    "format": " {percentage}%",
    "tooltip": false
  },

  "battery": {
    "format-charging": " {percentage}%",
    "format-discharging": " {percentage}%",
    "format-full": " {percentage}%",
    "tooltip": false
  },

  "custom/logout": {
    "format": "󰍃",
    "on-click": "wlogout",
    "tooltip": false
  }
}
